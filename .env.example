# grainbidcalc environment variables
# Copy to .env and fill in real values. .env is gitignored — never commit it.

# Supabase (PostgreSQL)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Claude API (LLM bid parsing)
ANTHROPIC_API_KEY=sk-ant-...

# Twilio (SMS inbound + outbound)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# Google Workspace (email ingestion + distribution)
GOOGLE_SERVICE_ACCOUNT_JSON=credentials/service-account.json
GMAIL_TARGET_EMAIL=markets@mapleviewgrain.ca

# CQG API (live futures prices)
CQG_API_KEY=
CQG_API_SECRET=

# Redis (Celery broker)
REDIS_URL=redis://localhost:6379/0

# App
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=production
SECRET_KEY=change-me-to-a-random-string
